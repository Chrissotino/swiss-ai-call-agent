# ─────────────────────────────────────────────────────────────
# Swiss AI Call Agent — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Anthropic / Claude ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ── Twilio (Telephony) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+41xxxxxxxxx
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ElevenLabs (TTS) ─────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID_DE=voice_id_for_german
ELEVENLABS_VOICE_ID_FR=voice_id_for_french
ELEVENLABS_VOICE_ID_IT=voice_id_for_italian

# ── Azure Speech Services (STT fallback) ─────────────────────
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=switzerlandnorth

# ── OpenAI Whisper (STT) ─────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ── PostgreSQL (Database) ────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/swiss_call_agent
DB_HOST=localhost
DB_PORT=5432
DB_NAME=swiss_call_agent
DB_USER=postgres
DB_PASSWORD=your_db_password

# ── Redis (Cache / Queue) ────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── API Server ───────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=your_jwt_secret_at_least_32_chars_long

# ── Bexio Integration ────────────────────────────────────────
BEXIO_API_KEY=your_bexio_api_key
BEXIO_BASE_URL=https://api.bexio.com/2.0

# ── Abacus Integration ───────────────────────────────────────
ABACUS_API_URL=https://your-abacus-instance.ch/api
ABACUS_API_KEY=your_abacus_api_key

# ── Dashboard ────────────────────────────────────────────────
DASHBOARD_PORT=3000
REACT_APP_API_URL=http://localhost:3001

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ── Confidence Thresholds ────────────────────────────────────
CONFIDENCE_AUTONOMOUS=90
CONFIDENCE_REVIEW=70

# ── Swiss Compliance ─────────────────────────────────────────
RECORDING_CONSENT_REQUIRED=true
DATA_RESIDENCY=switzerland
GDPR_COMPLIANT=true
